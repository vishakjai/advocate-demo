          "legendFormat": "{{ component }} component",
          "refId": "A"
        },
        {
          "datasource": {
            "uid": "$prometheus_ds"
          },
          "expr": "sum(\ngitlab_component_ops:rate:avg_over_time_1w{service=\"\", environment=\"$environment\", type=\"$type\", component=\"$component_ops\"} + \n$sigma * gitlab_component_ops:rate:stddev_over_time_1w{environment=\"$environment\", type=\"$type\", component=\"$component_ops\"}\n)",
          "format": "time_series",
          "hide": false,
          "interval": "1m",
          "intervalFactor": 1,
          "legendFormat": "upper",
          "refId": "B"
        },
        {
          "datasource": {
            "uid": "$prometheus_ds"
          },
          "expr": "sum(\nclamp_min(gitlab_component_ops:rate:avg_over_time_1w{service=\"\", environment=\"$environment\", type=\"$type\", component=\"$component_ops\"} \n- $sigma * gitlab_component_ops:rate:stddev_over_time_1w{environment=\"$environment\", type=\"$type\", component=\"$component_ops\"}, 0)\n)",
          "format": "time_series",
          "hide": false,
          "interval": "1m",
          "intervalFactor": 1,
          "legendFormat": "lower",
          "refId": "C"
        }
      ],
      "title": "$component_ops Service Operation Rates",
      "type": "graph"
