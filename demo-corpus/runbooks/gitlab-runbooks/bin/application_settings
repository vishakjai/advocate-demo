#!/bin/bash

set -efo pipefail

source "$(dirname "$0")/.admin_pat.lib.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo_err() {
  echo "$@" >&2
}

usage() {
  cat <<HELP >&2
USAGE:
  glsh application_settings [SUBCOMMAND] <setting_field> [-f <json_file>] [-u <gitlab_url>] [-r] [-h]

SUBCOMMANDS:
  get Get the field value
  set Set the field value using <json_file>

Supported <setting_field>:
  resource_usage_limits    Update resource usage limits. Visit https://runbooks.gitlab.com/sidekiq/sidekiq-concurrency-limit/#updating-db-duration-limits for more details.

Options:
  -f <json_file>   Path to JSON file (default: <setting_field>.json)
  -e [gstg,gprd]   Environment to validate/update
  -h               Show this help message

Examples:
  # Get the current settings
  glsh application_settings get resource_usage_limits -e gprd

  # Get the current settings and compare it to my_rules.json
  glsh application_settings get resource_usage_limits -e gprd -f my_rules.json

  # Update settings with my_rules.json
  glsh application_settings set resource_usage_limits -e gprd -f my_rules.json

  pat='your_token' GITLAB_URL='http://example.gitlab.com' application_settings get resource_usage_limits
HELP
  exit 2
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

print_message() {
  local color=$1
  local message=$2
  echo -e "${color}${message}${NC}" >&2
}

###################################################
# echos the API URL depending on which environment
# is set
###################################################
api_for_env() {
  echo "https://$(gitlab_host)/api/v4"
}

###################################################
# echos the host for the corresponding environment
###################################################
gitlab_host() {
  if [[ -n $GITLAB_URL ]]; then
    echo "$GITLAB_URL" | sed 's|https://||' | sed 's|/.*||'
    return 0
  fi

  case $env in
  gprd)
    echo "gitlab.com"
    ;;
  gstg)
    echo "staging.gitlab.com"
    ;;
  *)
    echo_err "Invalid environment '$env', must be 'gprd' or 'gstg'. Or pass in GITLAB_URL environment variable"
    return 1
    ;;
  esac
}

validate_setting_field() {
  SUPPORTED_FIELDS=("resource_usage_limits")
  # Check if SETTING_FIELD is in the supported fields array
  field_supported=false
  for field in "${SUPPORTED_FIELDS[@]}"; do
    if [[ $field == "$SETTING_FIELD" ]]; then
      field_supported=true
      break
    fi
  done

  if [[ $field_supported == false ]]; then
    print_message "$RED" "Error: Unsupported setting field: $SETTING_FIELD"
    echo "Supported fields: ${SUPPORTED_FIELDS[*]}"
    exit 1
  fi
}

parse_opts() {
  while getopts "f:e:h" opt; do
    case ${opt} in
    f)
      JSON_FILE="$OPTARG"
      ;;
    e)
      env="$OPTARG"
      ;;
    h)
      usage
      ;;
    \?)
      print_message "$RED" "Invalid option: -$OPTARG"
      usage
      ;;
    :)
      print_message "$RED" "Option -$OPTARG requires an argument"
      usage
      ;;
    esac
  done
}

check_dependencies() {
  print_message "$YELLOW" "Checking dependencies..."

  if ! command_exists curl; then
    print_message "$RED" "Error: curl is not installed. Please install curl first."
    exit 1
  fi

  if ! command_exists jq; then
    print_message "$RED" "Error: jq is not installed. Please install jq first."
    exit 1
  fi

  print_message "$GREEN" "✓ All dependencies are installed"
}

check_json_file() {
  if [[ $READ_ONLY_MODE == "false" ]]; then
    if [ ! -f "$JSON_FILE" ]; then
      print_message "$RED" "Error: JSON file '$JSON_FILE' not found!"
      echo "Please create the file or specify a different file with -f option"
      exit 1
    fi

    print_message "$GREEN" "✓ JSON file found: $JSON_FILE"

    if ! jq empty "$JSON_FILE" 2>/dev/null; then
      print_message "$RED" "Error: Invalid JSON in file '$JSON_FILE'"
      echo "Please check your JSON syntax"
      exit 1
    fi

    print_message "$YELLOW" "Encoding JSON data..."
    ENCODED_JSON=$(cat "$JSON_FILE" | jq -c . | jq -sRr @uri)

    if [[ -z $ENCODED_JSON ]]; then
      print_message "$RED" "Error: Failed to encode JSON data"
      exit 1
    fi

    print_message "$GREEN" "✓ JSON data encoded successfully"
    print_message "$GREEN" "✓ JSON file is valid"
  fi
}

check_pat() {
  print_message "$YELLOW" "Retrieving GitLab API token..."
  TOKEN=$(admin_pat)

  if [[ -z $TOKEN ]]; then
    print_message "$RED" "Error: Failed to get GitLab API token"
    exit 1
  fi

  print_message "$GREEN" "✓ GitLab API token obtained"
}

fetch_current_value() {
  print_message "$YELLOW" "Fetching current $SETTING_FIELD value..."

  CURRENT_BODY=$(curl --silent --fail-with-body --show-error \
    --header "PRIVATE-TOKEN: $TOKEN" \
    "$(api_for_env)/application/settings")

  CURRENT_VALUE=$(echo "$CURRENT_BODY" | jq ".${SETTING_FIELD}")

  if [[ $CURRENT_VALUE != "null" ]]; then
    if [[ $READ_ONLY_MODE == true ]]; then
      print_message "$GREEN" "✓ Successfully fetched $SETTING_FIELD"
      print_message "$YELLOW" "Current value of $SETTING_FIELD:"
      echo "$CURRENT_VALUE" | jq . 2>/dev/null || echo "$CURRENT_VALUE"
    else
      print_message "$YELLOW" "Current value:"
      echo "$CURRENT_VALUE" | jq . 2>/dev/null || echo "$CURRENT_VALUE"
    fi
  else
    if [[ $READ_ONLY_MODE == true ]]; then
      print_message "$YELLOW" "No value currently set for $SETTING_FIELD"
      exit 0
    else
      print_message "$YELLOW" "No current value set for $SETTING_FIELD"
    fi
  fi
}

compare_current_and_new() {
  if [[ $READ_ONLY_MODE == "true" ]] && [[ ! -f $JSON_FILE ]]; then
    return
  fi

  print_message "$YELLOW" "Comparing current and new values..."
  echo ""

  TEMP_CURRENT=$(mktemp)
  TEMP_NEW=$(mktemp)

  if [[ $CURRENT_VALUE != "null" ]] && [[ -n $CURRENT_VALUE ]]; then
    echo "$CURRENT_VALUE" | jq -S . >"$TEMP_CURRENT" 2>/dev/null || echo "$CURRENT_VALUE" >"$TEMP_CURRENT"
  else
    echo "{}" | jq . >"$TEMP_CURRENT"
  fi

  jq -S . "$JSON_FILE" >"$TEMP_NEW"

  diff --color=auto -u --label "Current value" "$TEMP_CURRENT" --label "New value (from $JSON_FILE)" "$TEMP_NEW" || true

  # Clean up temp files on exit
  trap 'rm -f "${TEMP_CURRENT}" "${TEMP_NEW}"' EXIT

  echo ""
}

update() {
  API_ENDPOINT="$(api_for_env)/application/settings?${SETTING_FIELD}=${ENCODED_JSON}"

  print_message "$YELLOW" "Update summary:"
  echo "  GitLab URL: $(api_for_env)"
  echo "  Setting field: $SETTING_FIELD"
  echo "  JSON file: $JSON_FILE"

  echo ""
  read -p "Do you want to proceed with the update? (y/N): " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    print_message "$YELLOW" "Operation cancelled by user"
    exit 0
  fi

  print_message "$YELLOW" "Sending request to GitLab API..."

  curl -s --fail-with-body --show-error -XPUT \
    --header "PRIVATE-TOKEN: $TOKEN" \
    "$API_ENDPOINT"

  print_message "$GREEN" "✓ Successfully updated GitLab $SETTING_FIELD!"

  print_message "$YELLOW" "Verifying the update..."

  UPDATED_VALUE=$(curl -s --fail-with-body --show-error \
    --header "PRIVATE-TOKEN: $TOKEN" \
    "$(api_for_env)/application/settings" | jq ".${SETTING_FIELD}")

  if [[ $UPDATED_VALUE != "null" ]]; then
    print_message "$GREEN" "✓ Update verified successfully!"
    echo "New value of $SETTING_FIELD:"
    echo "$UPDATED_VALUE" | jq . 2>/dev/null || echo "$UPDATED_VALUE"

    EXPECTED_VALUE=$(jq -Sc . "$JSON_FILE")
    ACTUAL_VALUE=$(echo "$UPDATED_VALUE" | jq -Sc .)

    if [[ $EXPECTED_VALUE == "$ACTUAL_VALUE" ]]; then
      print_message "$GREEN" "✓ The value matches exactly what was requested"
    else
      print_message "$YELLOW" "⚠ The value differs from what was requested"
      echo "Expected:"
      jq . "$JSON_FILE"
      echo "Actual:"
      echo "$UPDATED_VALUE" | jq .
    fi
  else
    print_message "$YELLOW" "⚠ Could not verify the update"
  fi
}

main() {
  case $1 in
  get)
    READ_ONLY_MODE="true"
    ;;
  set)
    READ_ONLY_MODE="false"
    ;;
  *)
    usage
    ;;
  esac
  SETTING_FIELD="$2"
  shift 2

  validate_setting_field
  parse_opts "$@"
  check_dependencies
  check_json_file
  check_pat

  fetch_current_value
  compare_current_and_new

  if [[ $READ_ONLY_MODE == "true" ]]; then
    exit 0
  fi

  update
}

main "$@"
